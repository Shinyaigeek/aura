{
  "expo": {
    "name": "aura",
    "slug": "aura",
    "scheme": "aura",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0b0b0b",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.shinyaigeek.aura",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "dev.shinyaigeek.aura",
      "adaptiveIcon": {
        "backgroundColor": "#0b0b0b"
      },
      "splash": {
        "backgroundColor": "#0b0b0b",
        "resizeMode": "contain"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0b0b",
          "resizeMode": "contain"
        }
      ]
    ]
  }
}
