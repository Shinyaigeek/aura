{
  "expo": {
    "name": "aura",
    "slug": "aura",
    "scheme": "aura",
    "version": "0.0.47",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0b0b0b",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "dev.shinyaigeek.aura",
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "package": "dev.shinyaigeek.aura",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0b0b0b"
      },
      "splash": {
        "backgroundColor": "#0b0b0b",
        "resizeMode": "contain"
      }
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0b0b0b",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "aura uses your photo library to send images to your aura-server."
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "aura uses the microphone so you can dictate prompts.",
          "speechRecognitionPermission": "aura uses speech recognition to turn your voice into text.",
          "androidSpeechServicePackages": ["com.google.android.googlequicksearchbox"]
        }
      ]
    ]
  }
}
